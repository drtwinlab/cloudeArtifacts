{
  "mcpServers": {
    "design-inspiration": {
      "type": "stdio",
      "command": "npx",
      "args": ["-y", "github:notsointresting/design-inspiration-mcp"]
    },
    "iconify-mcp": {
      "type": "stdio",
      "command": "npx",
      "args": ["-y", "iconify-mcp-server@latest"]
    },
    "pixabay-mcp": {
      "type": "stdio",
      "command": "npx",
      "args": ["-y", "pixabay-mcp"],
      "env": {
        "PIXABAY_API_KEY": "${PIXABAY_API_KEY}"
      }
    },
    "chrome-devtools": {
      "type": "stdio",
      "command": "npx",
      "args": ["chrome-devtools-mcp@latest"]
    }
  }
}
